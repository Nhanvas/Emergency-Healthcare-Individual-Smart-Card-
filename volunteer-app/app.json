{
  "expo": {
    "name": "EHIS Volunteer",
    "slug": "volunteer-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Volunteer-logo.png",
    "scheme": "volunteer-app",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/Volunteer-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#E53935"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ehiscard.volunteerapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Volunteer-logo.png",
        "backgroundColor": "#E53935"
      },
      "package": "com.redcross.volunteerapp",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Volunteer-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#E53935"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Emergency Volunteer needs your location to dispatch you to nearby incidents."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#E53935"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "feb96668-8a34-4af7-ad06-a4f5e0dd93c7"
      }
    }
  }
}