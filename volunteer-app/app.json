{
  "expo": {
    "name": "Emergency Volunteer",
    "slug": "volunteer-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2E7D32"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "package": "com.redcross.volunteerapp",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Emergency Volunteer needs your location to dispatch you to nearby incidents."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#2E7D32"
        }
      ]
    ],
    "scheme": "volunteer-app",
    "newArchEnabled": true,
    "experiments": {
      "typedRoutes": true
    }
  }
}